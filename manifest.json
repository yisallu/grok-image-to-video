{
  "manifest_version": 3,
  "name": "Grok 图生视频 (Alt+点击)",
  "version": "1.0.3",
  "description": "Alt+左键点击网页任意图片/视频帧,先微调提示词,再调用 xAI Grok 图生视频并在新标签页显示进度。",
  "permissions": ["storage", "notifications", "declarativeNetRequest"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "Grok 图生视频设置",
    "default_popup": "options.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
